# Copy this file to .env.local-agent and fill values.

# EC2 customs push endpoint
SYNC_API_URL=http://43.203.237.154:8080/api/clients/sync/push

# Must match CLIENT_SYNC_AGENT_TOKEN on EC2
CLIENT_SYNC_AGENT_TOKEN=replace-with-strong-secret

# Target customs companyId in EC2 DB
SYNC_COMPANY_ID=10

# Source name shown in server logs
SYNC_SOURCE=local-ddeal-agent

# Pull only codes with this prefix (e.g. 00*)
SYNC_CODE_PREFIX=00

# Batch size per request
SYNC_BATCH_SIZE=200

# Agent mode: once | daemon
SYNC_MODE=once

# Input mode: db | mock
# - db: read from LOCAL_DB_* (DDeal)
# - mock: read from SYNC_FIXTURE_FILE JSON
SYNC_INPUT_MODE=db

# JSON fixture path for mock mode
SYNC_FIXTURE_FILE=./fixtures/ddeal_sample.json

# Daemon interval seconds (SYNC_MODE=daemon only)
SYNC_INTERVAL_SECONDS=300

# Timeouts / retry
SYNC_CONNECT_TIMEOUT_SECONDS=5
SYNC_HTTP_TIMEOUT_SECONDS=20
SYNC_HTTP_VERIFY_SSL=true
SYNC_RETRY_MAX=3
SYNC_RETRY_BACKOFF_SECONDS=2

# Local 통관 DB (DDeal) connection
LOCAL_DB_HOST=127.0.0.1
LOCAL_DB_PORT=3306
LOCAL_DB_NAME=ncustoms
LOCAL_DB_USER=kcba
LOCAL_DB_PASSWORD=change-me
# NCustoms는 보통 euckr 환경입니다. (필요시 utf8mb4로 변경 테스트)
LOCAL_DB_CHARSET=euckr
# Optional (example): euckr_korean_ci
LOCAL_DB_COLLATION=

# Local checkpoint file path
SYNC_CHECKPOINT_FILE=./.client-sync-checkpoint.json

# Last run status file path (for troubleshooting)
SYNC_STATUS_FILE=./.client-sync-status.json

# -----------------------------
# NCustoms temp-save worker
# -----------------------------
# Cloud queue base endpoint
TEMP_SAVE_API_BASE_URL=http://43.203.237.154:8080/api/ncustoms/temp-save/jobs
# Token for temp-save worker (defaults to CLIENT_SYNC_AGENT_TOKEN if empty)
NCUSTOMS_TEMP_SAVE_AGENT_TOKEN=
# Company id to claim temp-save jobs (defaults to SYNC_COMPANY_ID if empty)
TEMP_SAVE_COMPANY_ID=
# Worker mode: once | daemon
TEMP_SAVE_MODE=daemon
# Poll interval in daemon mode
TEMP_SAVE_INTERVAL_SECONDS=10
# Claim batch size per poll
TEMP_SAVE_CLAIM_LIMIT=1
# Optional worker id (defaults to <hostname>-ncustoms-worker)
TEMP_SAVE_WORKER_ID=
# Timeouts / retry
TEMP_SAVE_CONNECT_TIMEOUT_SECONDS=5
TEMP_SAVE_HTTP_TIMEOUT_SECONDS=20
TEMP_SAVE_HTTP_VERIFY_SSL=true
TEMP_SAVE_RETRY_MAX=3
TEMP_SAVE_RETRY_BACKOFF_SECONDS=2
